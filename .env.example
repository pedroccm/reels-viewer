# Password to unlock editing (add tags / hide videos). Set this in Netlify env too.
EDIT_PASSWORD=change-me

# Deploy-only (set in Netlify site settings, not needed for local dev):
#   MANIFEST_URL        public R2 URL of the manifest JSON
#   NETLIFY_SITE_ID     so the functions can reach Netlify Blobs
#   NETLIFY_AUTH_TOKEN  same
